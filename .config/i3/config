#############################################
#               I3 CONFIG
#           Arch Linux Rice
#############################################


#############################################
#                VARIABLES
#############################################

set $mod Mod4
set $term alacritty
set $f_manager thunar
set $browser vivaldi


#############################################
#               APPEARANCE
#############################################

# Font
font pango:JetBrainsMono Nerd Font 9

# Borders
default_border pixel 3

# Gaps
gaps inner 5
gaps outer 12
gaps top 37


#############################################
#               WINDOW COLORS
#############################################

client.focused          #ff4f9a #0b0b0b #ff4f9a #ff4f9a #ff4f9a
client.focused_inactive #333333 #0b0b0b #888888 #333333 #333333
client.unfocused        #222222 #0b0b0b #888888 #222222 #222222
client.urgent           #ff003c #ff003c #ffffff #ff003c #ff003c


#############################################
#               AUTOSTART
#############################################

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id nm-applet
exec --no-startup-id dunst
exec --no-startup-id picom --config ~/.config/picom/picom.conf
exec --no-startup-id /usr/bin/lxqt-policykit-agent
exec_always --no-startup-id autotiling --limit 2 --splitratio 1.61

# DPMS timeouts
exec_always --no-startup-id xset s 300 0
exec_always --no-startup-id xset dpms 0 0 300

# xss-lock
exec_always --no-startup-id xss-lock --transfer-sleep-lock -- ~/.config/i3/lock.sh


# Wallpaper
exec_always --no-startup-id feh --bg-fill ~/arch-i3-rice/wallpapers/wp11886213-3827729853.jpg

# Polybar
exec_always --no-startup-id ~/.config/polybar/launch.sh

# Keyboard layout
exec --no-startup-id setxkbmap -layout us,ru,kz -option grp:win_space_toggle

# powermenu 
bindsym $mod+p exec --no-startup-id ~/.config/rofi/power-profile.sh


#############################################
#               SCREENSHOTS
#############################################

# Region screenshot
bindsym Print exec --no-startup-id flameshot gui

# Full screen screenshot
bindsym Shift+Print exec --no-startup-id flameshot full

# Active window screenshot
bindsym $mod+Print exec --no-startup-id flameshot screen

# Copy region to clipboard
bindsym Ctrl+Print exec --no-startup-id flameshot gui --clipboard


#############################################
#               AUDIO KEYS
#############################################

set $refresh_i3status killall -SIGUSR1 i3status

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

################################################
#              BRIGHRNESSCTL
################################################

bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

#############################################
#               APPLICATIONS
#############################################

# Terminal
bindsym $mod+Return exec $term
for_window [class="Alacritty"] border pixel 3

# Launcher
bindsym $mod+d exec --no-startup-id rofi -show drun
bindsym $mod+Shift+d exec --no-startup-id rofi -show window

# File manager
bindsym $mod+e exec --no-startup-id $f_manager

# Browser
bindsym $mod+b exec $browser

# Power menu
bindsym XF86PowerOff exec ~/.config/rofi/powermenu.sh

# Network Manager
bindsym $mod+n exec --no-startup-id ronema

# Telegram
bindsym $mod+t exec --no-startup-id Telegram

# Bluetooth-manager
bindsym $mod+c exec --no-startup-id rofi-bluetooth


#############################################
#       ASSIGN APPLICATIONS TO WORKSPACES
#############################################

# Workspace1


# Workspace 2
for_window [class="virt-manager"] move to workspace $ws2, workspace $ws2

# Workspace 3
for_window [class="code-oss"] move to workspace $ws3, workspace $ws3

# Workpace 4
for_window [class="DesktopEditors"] move to workspace $ws4, workspace $ws4

# Workpace 5
# Workpace 6
# Workpace 7

# Workpace 8
for_window [class="discord"] move to workspace $ws8, workspace $ws8
for_window [class="Telegram"] move to workspace $ws8, workspace $ws8
# Workpace 9
# Workpace 10
for_window [class="Spotify"] move to workspace $ws10, workspace $ws10


#############################################
#            LAYOUT LOADING
#############################################

bindsym $mod+F1 workspace $ws3; append_layout ~/.config/i3/lab_layout.json; exec code-oss; exec thunar; exec alacritty
bindsym $mod+F10 exec --no-startup-id ~/.config/i3/start_low-cortisol.sh

#############################################
#             WINDOW MARKS
#############################################

bindsym $mod+m exec --no-startup-id "i3-msg mark $(rofi -dmenu -p 'Set Mark')"

bindcode $mod+48 exec --no-startup-id "i3-msg [con_mark=$(rofi -dmenu -p 'Go to Mark')] focus"


#############################################
#               WINDOW CONTROL
#############################################


# Kill window
bindsym $mod+Shift+q kill

# Fullscreen
bindsym $mod+f fullscreen toggle

# Floating
bindsym Mod1+Shift+space floating toggle

# Focus parent
bindsym $mod+a focus parent

# Sticky toggle
bindsym $mod+Shift+s sticky toggle; exec --no-startup-id dunstify -u low -t 1000 "Sticky" "Toggled"


#############################################
#            SCRATCHPADS
#############################################

for_window [class="ScratchTerm"] floating enable, resize set 1000 600, border pixel 5, move scratchpad
bindsym $mod+u exec --no-startup-id ~/.config/i3/scratchpad.sh


bindsym $mod+minus move scratchpad
bindsym $mod+equal scratchpad show, move position center


#############################################
#               FOCUS WINDOWS
#############################################

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Arrow keys
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right


#############################################
#               MOVE WINDOWS
#############################################

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
#bindsym $mod+Shift+l move right

# Arrow keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right


#############################################
#               LAYOUT CONTROL
#############################################

# Split
bindsym $mod+Ctrl+h split h
bindsym $mod+Ctrl+v split v

# Layouts
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed

# Toggle focus mode
bindsym Mod1+space focus mode_toggle


#############################################
#               WORKSPACES
#############################################

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Switch workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move window to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10


#############################################
#               SYSTEM CONTROL
#############################################

# Reload config
bindsym $mod+Shift+c reload

# Restart i3
bindsym $mod+Shift+r restart

# Exit i3
bindsym $mod+Shift+e exec "i3-nagbar -t warning \
-m 'You pressed the exit shortcut. Do you really want to exit i3?' \
-B 'Yes, exit i3' 'i3-msg exit'"


############################################
#              Player Control
###########################################


bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioStop exec playerctl stop

bindsym $mod+Shift+p exec playerctl play-pause
bindsym $mod+Shift+n exec playerctl next
bindsym $mod+Shift+b exec playerctl previous


#############################################
#               RESIZE MODE
#############################################

mode "resize" {

    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

